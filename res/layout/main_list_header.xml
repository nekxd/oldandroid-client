<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#f2f2f2">

    <RelativeLayout
        android:id="@+id/promoMainRoot"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:background="@drawable/bg_promotion_main"
        android:paddingLeft="12dp"
        android:paddingTop="10dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/txtPromoType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:text="apps"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:shadowColor="#88000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="2.0" />

        <LinearLayout
            android:id="@+id/promoCard"
            android:layout_width="178dp"
            android:layout_height="66dp"
            android:layout_below="@id/txtPromoType"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="5dp"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">

            <ImageView
                android:id="@+id/promoIcon1"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/icon_placeholder" />

            <ImageView
                android:id="@+id/promoIcon2"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginLeft="9dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/icon_placeholder" />

            <ImageView
                android:id="@+id/promoIcon3"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginLeft="9dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/icon_placeholder" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/promoMirrorsRow"
            android:layout_width="178dp"
            android:layout_height="44dp"
            android:layout_below="@id/promoCard"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="-15dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">

            <ImageView
                android:id="@+id/promoMirror1"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:adjustViewBounds="true"
                android:alpha="0.20"
                android:scaleType="fitXY"
                android:scaleY="-1"
                android:src="@drawable/icon_placeholder" />

            <ImageView
                android:id="@+id/promoMirror2"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginLeft="9dp"
                android:adjustViewBounds="true"
                android:alpha="0.20"
                android:scaleType="fitXY"
                android:scaleY="-1"
                android:src="@drawable/icon_placeholder" />

            <ImageView
                android:id="@+id/promoMirror3"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginLeft="9dp"
                android:adjustViewBounds="true"
                android:alpha="0.20"
                android:scaleType="fitXY"
                android:scaleY="-1"
                android:src="@drawable/icon_placeholder" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtBrowseCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/promoMirrorsRow"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="5dp"
            android:text="Browse category"
            android:textColor="#3a3a3a"
            android:textSize="15sp" />
    </RelativeLayout>

    <TextView
        android:id="@+id/txtSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_section_header"
        android:paddingLeft="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="@string/top_apps_games"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
